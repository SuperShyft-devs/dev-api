# Application Settings
APP_NAME=Supershyft API
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
DEBUG=True

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/db

# Read-only SQLite file written by the production health-check cron script.
# Default on Linux servers: /var/www/health-check-db/health.db
HEALTH_CHECK_DB_PATH=/var/www/health-check-db/health.db

# Pytest: separate Postgres database for integration tests. When set, conftest
# points DATABASE_URL at this value, runs Alembic + db.seed once per session,
# and wipes the public schema after the run. Your dev DATABASE_URL is untouched.
# TEST_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/supershyft_test

DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# JWT Settings
# IMPORTANT: Generate a strong secret key for production
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Separate HMAC secrets (fall back to JWT_SECRET_KEY if not set)
OTP_HMAC_SECRET=
REFRESH_TOKEN_SECRET=

# CORS Settings
# Comma-separated list of allowed origins (include Live Server / VS Code: :5500)
# Include every admin/app origin that calls the API in the browser (comma-separated).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5500,http://localhost:5500,https://admin.supershyft.com

# Security Settings
BCRYPT_ROUNDS=12

# OTP Settings (Development only)
# Set to True to log OTP codes to terminal for testing
OTP_LOG_TO_TERMINAL=True
# Set OTP webhook URL to enable real OTP sending
# Example: https://webhook.whatapi.in/webhook/<token>
OTP_WEBHOOK_URL=
# Default country code to prefix when phone does not include country code
OTP_COUNTRY_CODE=91
# Timeout for OTP webhook HTTP request
OTP_WEBHOOK_TIMEOUT_SECONDS=10
# Set to True to allow one static OTP for any phone (dev only; keep False in production)
ALLOW_BYPASS_OTP=False
# The OTP value accepted when ALLOW_BYPASS_OTP is True
BYPASS_OTP=654321
# Per-phone bypass: comma-separated phone:otp (works when ALLOW_BYPASS_OTP is False)
# Example: +66961275268:654321,8103946120:111111
BYPASS_OTP_BY_PHONE=

# Media uploads
MEDIA_ROOT=/var/www/backend/media
MEDIA_BASE_URL=http://localhost:8000/media
USER_PROFILE_PHOTO_MAX_MB=2
ORG_LOGO_MAX_MB=5
EXPERT_PROFILE_PHOTO_MAX_MB=2
PACKAGE_IMAGE_MAX_MB=5
# User PDF uploads (bio-ai, blood-parameters); MAX_REQUEST_BODY_MB should exceed this for multipart overhead
USER_PDF_UPLOAD_MAX_MB=10
MAX_REQUEST_BODY_MB=25

# Metsights integration settings
METSIGHTS_BASE_URL=
METSIGHTS_API_KEY=
METSIGHTS_TIMEOUT_SECONDS=15

# Nutrition API settings
NUTRITION_API_URL=https://nutrition.supershyft.com/calculate
NUTRITION_API_KEY=
NUTRITION_API_TIMEOUT_SECONDS=15

# Healthians Bridge API
HEALTHIANS_BASE_URL=https://hbridge.healthians.com/api
HEALTHIANS_API_KEY=
HEALTHIANS_SECRET_KEY=
HEALTHIANS_CHECKSUM_KEY=

# Healthians inbound webhook forwarding (comma-separated URLs)
HEALTHIANS_WEBHOOK_FORWARD_URL=
HEALTHIANS_WEBHOOK_FORWARD_TIMEOUT_SECONDS=15

# Notification service (n8n webhooks)
NOTIFICATION_SERVICE_BASE_URL=https://n8n.supershyft.com
NOTIFICATION_SERVICE_TIMEOUT_SECONDS=15
NOTIFICATION_API_KEY=

# Razorpay (test keys for development)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXX
