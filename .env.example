# Application Settings
APP_NAME=Supershyft API
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
DEBUG=True

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/db

# Pytest: separate Postgres database for integration tests. When set, conftest
# points DATABASE_URL at this value, runs Alembic + db.seed once per session,
# and wipes the public schema after the run. Your dev DATABASE_URL is untouched.
# TEST_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/supershyft_test

DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# JWT Settings
# IMPORTANT: Generate a strong secret key for production
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Settings
# Comma-separated list of allowed origins (include Live Server / VS Code: :5500)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5500,http://localhost:5500

# Security Settings
BCRYPT_ROUNDS=12

# OTP Settings (Development only)
# Set to True to log OTP codes to terminal for testing
OTP_LOG_TO_TERMINAL=True
# Set OTP webhook URL to enable real OTP sending
# Example: https://webhook.whatapi.in/webhook/<token>
OTP_WEBHOOK_URL=
# Default country code to prefix when phone does not include country code
OTP_COUNTRY_CODE=91
# Timeout for OTP webhook HTTP request
OTP_WEBHOOK_TIMEOUT_SECONDS=10
# Set to True to allow static OTP 654321 for testing
ALLOW_BYPASS_OTP=False

# Media uploads
MEDIA_ROOT=/var/www/backend/media
MEDIA_BASE_URL=http://localhost:8000/media
USER_PROFILE_PHOTO_MAX_MB=2
ORG_LOGO_MAX_MB=5

# Metsights integration settings
METSIGHTS_BASE_URL=
METSIGHTS_API_KEY=
METSIGHTS_TIMEOUT_SECONDS=15

# Razorpay (test keys for development)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXX
