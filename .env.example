# Application Settings
APP_NAME=Supershyft API
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
DEBUG=True

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/db

DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# JWT Settings
# IMPORTANT: Generate a strong secret key for production
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Settings
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Security Settings
BCRYPT_ROUNDS=12

# OTP Settings (Development only)
# Set to True to log OTP codes to terminal for testing
OTP_LOG_TO_TERMINAL=True
# Set to True to allow static OTP 654321 for testing
ALLOW_BYPASS_OTP=False
